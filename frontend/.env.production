# Loaded ONLY when Vite builds in production mode (npm run build / deploy).
# Higher priority than .env.local, so this overrides the localhost URL
# that .env.local sets for local dev. Without this file, production
# builds inherit .env.local's localhost URL, which doesn't exist on
# users' machines — they'd see a CORS / "failed to fetch" error.
VITE_API_URL=https://employai-backend-v2.onrender.com
